# NexusAgent — Environment Variables Template
# Copy this file to .env and fill in your keys.
# DO NOT commit .env to version control.

# ─── LLM Provider ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Tool API Keys ───────────────────────────────────────────────────────────
WEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Network (optional) ──────────────────────────────────────────────────────
# Required only if DuckDuckGo search is blocked in your region
HTTP_PROXY=

# ─── Local Model Serving (optional) ──────────────────────────────────────────
LOCAL_LLM_HOST=localhost
LOCAL_LLM_PORT=8888
